#!/usr/bin/env bash
# screen-slider : one master slider (0-100) for all 3 calibrated screens.
mstate="$HOME/.config/screen-master"
cur=$(cat "$mstate" 2>/dev/null); [[ $cur =~ ^[0-9]+$ ]] || cur=100
M=$(zenity --scale --title="Screen dimmer" --text="All screens (eye-calibrated)" \
      --min-value=0 --max-value=100 --value="$cur" --step=5 2>/dev/null) || exit 0
echo "$M" > "$mstate"
exec "$HOME/.local/bin/screen-apply"

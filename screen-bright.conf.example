# Per-screen calibration. Tune each BASE (0-100) until the 3 screens look
# EQUALLY bright by eye at master=100, daytime. This is the only thing you edit.
#   workflow: echo 100 > ~/.config/screen-master ; edit a BASE ; run ~/.local/bin/screen-apply ; eyeball ; repeat
BASE_LAPTOP=60     # eDP internal panel
BASE_LENOVO=85     # LEN G32qc-10
BASE_ARZOPA=75     # ARZOPA portable

# Extra global dim at full night (Night Light at its min temp). 100 = no extra dim, 0 = blackest.
NIGHT_SCALE=55

# Per-screen calibration. Tune each BASE (0-100) until the 3 screens look
# EQUALLY bright by eye at master=100, daytime. BASE is also the per-screen CEILING:
# the slider (master) and Night Light only scale DOWN from it, never above.
#   workflow: match screens by eye (physical buttons), then run `screen-calibrate`
#   manual:   echo 100 > ~/.config/screen-master ; edit a BASE ; run screen-apply ; eyeball ; repeat
BASE_LAPTOP=89     # eDP internal panel       (tinee eye-calibrated)
BASE_LENOVO=100    # LEN G32qc-10             (tinee eye-calibrated)
BASE_ARZOPA=73     # ARZOPA portable -- keep <= ARZOPA_MAX (tinee eye-calibrated)

# ARZOPA blacks out above 73% (tested). Hard safety ceiling, clamped in screen-apply.
ARZOPA_MAX=73

# Extra global dim at full night (Night Light at its min temp). 100 = no extra dim, 0 = blackest.
NIGHT_SCALE=55
